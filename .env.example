# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# S3
S3_BUCKET_NAME=ai-doc-pipeline-YOUR-UNIQUE-SUFFIX
S3_FRONTEND_BUCKET_NAME=ai-doc-pipeline-frontend-YOUR-UNIQUE-SUFFIX

# DynamoDB
DYNAMODB_TABLE_NAME=DocumentResults

# SSM Parameter Store
SSM_PARAMETER_NAME=/ai-doc-pipeline/openai-api-key

# OpenAI (used only during deployment to store in SSM)
OPENAI_API_KEY=sk-your-openai-api-key-here
